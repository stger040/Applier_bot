###################################################### CONFIGURE YOUR TOOLS HERE ######################################################


# Login Credentials for LinkedIn (Optional)
username = ""       # Enter your LinkedIn email in the quotes (leave "" to log in manually)
password = ""       # Enter your LinkedIn password in the quotes (leave "" to log in manually)


## Artificial Intelligence (Beta, Optional)
# Use AI? Leave False for the simplest setup (no API key needed).
use_AI = False                         # True or False, Note: True or False are case-sensitive

# Select AI Provider
ai_provider = "openai"               # "openai", "deepseek", "gemini"

# Your LLM url or other AI api url and port
llm_api_url = "https://api.openai.com/v1/"       # Don't forget the trailing slash "/"

# Your LLM API key or other AI API key
llm_api_key = ""                     # Enter your API key in the quotes. Leave "" if use_AI = False.

# Your LLM model name or other AI model name
llm_model = "gpt-4o-mini"            # Examples: "gpt-4o-mini", "gpt-4o", "gemini-1.5-flash", "deepseek-chat"

llm_spec = "openai"                  # "openai", "openai-like", "openai-like-github", "openai-like-mistral"

# Do you want to stream AI output?
stream_output = False                # True or False
